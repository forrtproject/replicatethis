---
layout: base.njk
title: Nominations Registry
---
<h1 style="margin-bottom: 5px;">Nominations Registry</h1>
<p style="font-size: 1.1rem; color: var(--text-muted); margin-bottom: 25px;">
  A curated collection of distinguished research papers recognized by the community as highly valuable for replication or reproduction.
</p>

<div class="registry-controls">
  <div class="search-container">
    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    <input type="text" id="searchInput" placeholder="Search by paper, journal, author, discipline..." class="search-bar">
  </div>
  
  <div class="filter-options">
    <label class="custom-checkbox">
      <input type="checkbox" id="check-replication" checked>
      Replication
    </label>
    <label class="custom-checkbox">
      <input type="checkbox" id="check-reproduction" checked>
      Reproduction
    </label>
    <label class="custom-checkbox">
      <input type="checkbox" id="check-claimed">
      Exclude Claimed Studies
    </label>
  </div>
</div>
<p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px;"><em>Click table headers to sort</em></p>

<div class="table-responsive">
  <table class="academic-table" id="registryTable">
    <thead>
      <tr>
        <th onclick="sortTable(0)" style="width: 120px;">Date &#x21D5;</th>
        <th onclick="sortTable(1)">Nominated Work &#x21D5;</th>
        <th onclick="sortTable(2)">Type &#x21D5;</th>
      </tr>
    </thead>
    <tbody>
      {% for nom in nominations %}
      <tr class="main-row" data-type="{{ nom.type }}" data-claimed="{{ nom.isClaimed }}">
        <td data-sort="{{ nom.date }}">{{ nom.formattedDate }}</td>
        <td>
          <strong style="font-size: 1.05rem;">
            <a href="{{ '/nomination/' | url }}{{ nom.id }}/">{{ nom.title }}</a>
          </strong>
          {% if nom.isClaimed %}
            <span class="type-badge type-claimed" style="margin-left: 5px;">CLAIMED ✍️</span>
          {% endif %}
          <br>
          <span style="font-size: 0.85rem; color: var(--text-muted);">{{ nom.Journal }} | {{ nom.Discipline }}</span>
        </td>
        <td>
          <span class="type-badge type-{{ nom.type | lower }}">{{ nom.type }}</span>
        </td>
      </tr>
      {% else %}
      <tr>
        <td colspan="3" style="text-align: center; padding: 30px;">
          <em>No approved nominations found yet. Check back soon or submit one!</em>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<script>
// Attach Event Listeners
document.getElementById('searchInput').addEventListener('keyup', runFilters);
document.getElementById('check-replication').addEventListener('change', runFilters);
document.getElementById('check-reproduction').addEventListener('change', runFilters);
document.getElementById('check-claimed').addEventListener('change', runFilters);

function runFilters() {
  const searchVal = document.getElementById('searchInput').value.toLowerCase();
  const showRep = document.getElementById('check-replication').checked;
  const showRepro = document.getElementById('check-reproduction').checked;
  const excludeClaimed = document.getElementById('check-claimed').checked;
  
  const rows = document.querySelectorAll('.main-row');

  rows.forEach(row => {
    const text = row.innerText.toLowerCase();
    const type = row.getAttribute('data-type');
    const isClaimed = row.getAttribute('data-claimed') === 'true';

    let typeMatch = false;
    if (showRep && type === 'Replication') typeMatch = true;
    if (showRepro && type === 'Reproduction') typeMatch = true;

    let claimMatch = true;
    if (excludeClaimed && isClaimed) claimMatch = false;

    const searchMatch = text.includes(searchVal);

    row.style.display = (typeMatch && claimMatch && searchMatch) ? '' : 'none';
  });
}

let sortAsc = true;
function sortTable(colIndex) {
  const tbody = document.querySelector("#registryTable tbody");
  const rowsArray = Array.from(tbody.querySelectorAll('.main-row'));
  rowsArray.sort((a, b) => {
    let valA = a.cells[colIndex].innerText.trim();
    let valB = b.cells[colIndex].innerText.trim();
    if (colIndex === 0) {
      valA = a.cells[colIndex].getAttribute('data-sort');
      valB = b.cells[colIndex].getAttribute('data-sort');
    }
    if (valA < valB) return sortAsc ? -1 : 1;
    if (valA > valB) return sortAsc ? 1 : -1;
    return 0;
  });
  sortAsc = !sortAsc;
  rowsArray.forEach(row => tbody.appendChild(row));
}
</script>
