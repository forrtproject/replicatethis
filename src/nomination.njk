---
layout: base.njk
pagination:
  data: nominations
  size: 1
  alias: nom
permalink: "nomination/{{ nom.id }}/"
---
<a href="{{ '/browse/' | url }}" class="back-link" style="display:inline-block; margin-bottom: 20px;">&larr; Back to Browse</a>

<h1 style="margin-top: 0;">{{ nom.title }}</h1>

<div class="meta-box" style="border-top: 3px solid var(--gold);">
  <p><strong>Nominated by:</strong> <a href="https://github.com/{{ nom.nominator }}" target="_blank">@{{ nom.nominator }}</a></p>
  <p><strong>DOI:</strong> <a href="https://doi.org/{{ nom.DOI }}" target="_blank">{{ nom.DOI }}</a></p>
  <p><strong>Journal:</strong> {{ nom.Journal }}</p>
  <p><strong>Discipline:</strong> {{ nom.Discipline }}</p>
  <p><strong>Request Type:</strong> <span class="type-badge type-{{ nom.type | lower }}">{{ nom.type }}</span></p>
</div>

<!-- Changed from h3 (Boxes) to h4 (Clean Underlines) for denser formatting -->
<div style="margin-top: 40px;">
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Scientific Justification</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Scientific Justification'] }}</p>

  {% if nom['Data Location (if Reproduction)'] %}
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Data Location</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Data Location (if Reproduction)'] }}</p>
  {% endif %}

  {% if nom['Suggested Robustness Checks'] %}
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Suggested Robustness Checks</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Suggested Robustness Checks'] }}</p>
  {% endif %}

  {% if nom['Suggested Deviations from Original Design'] %}
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Suggested Deviations</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Suggested Deviations from Original Design'] }}</p>
  {% endif %}
</div>

<!-- Comments Section -->
<hr style="margin: 50px 0 30px 0; border: 0; border-top: 1px solid var(--border);">
<h2 id="comments" class="serif">Comments</h2>

{% if nom.commentCount == 0 %}
  <p style="color: var(--text-muted); margin-bottom: 20px;">No comments yet on this nomination.</p>
{% else %}
  <div style="margin-bottom: 30px;">
    {% for comment in nom.discussion %}
      <div style="background: var(--bg); padding: 20px; border: 1px solid var(--border); border-radius: 0px; margin-bottom: 15px;">
        <strong style="color: var(--gold);">@{{ comment.author }}</strong> 
        <span style="color: var(--text-muted); font-size: 0.85rem; margin-left: 10px;">{{ comment.date }}</span>
        <div style="margin-top: 10px; font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap;">{{ comment.body }}</div>
      </div>
    {% endfor %}
  </div>
{% endif %}

<a href="{{ nom.url }}" target="_blank" class="nav-submit" style="display: inline-block; font-size: 1rem;">Join discussion on GitHub &rarr;</a>
