<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Replicate This") }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <script>
    if (localStorage.getItem('theme') === 'dark') { document.documentElement.classList.add('dark-mode'); }
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container header-top">
      <h1 class="site-title">
        <a href="{{ '/' | url }}">
          <svg class="logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 2h7l4 4v4a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z" />
            <path d="M14 2v4h4" />
            <line x1="3" y1="13" x2="21" y2="13" stroke-width="1" stroke-dasharray="3 3"/>
            <path d="M7 24h7l4-4v-4a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1z" opacity="0.4"/>
            <path d="M14 24v-4h4" opacity="0.4" />
          </svg>
          Replicate This
        </a>
      </h1>
      <div class="sub-headline">A Community Registry for Scientific Verification</div>
    </div>
    
    <div class="nav-wrapper">
      <div class="container" style="padding: 0;">
        <nav class="main-nav">
          <a href="{{ '/' | url }}">Home</a>
          <a href="{{ '/browse/' | url }}">Nominations</a>
          <a href="{{ '/leaderboards/' | url }}">Leaderboards</a>
          <a href="https://github.com/forrtproject/replicatethis/issues/new?template=nomination.yml" target="_blank" class="nav-nominate">Nominate</a>
          <a href="{{ '/coc/' | url }}">COC</a>
          <a href="{{ '/about/' | url }}">About</a>
          <button id="darkModeToggle" class="dark-toggle" aria-label="Toggle Dark Mode">
            <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
            <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          </button>
        </nav>
      </div>
    </div>
  </header>
  
  <main class="container">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>This is a prototype project developed by Lukas Röseler with Gemini 3.1 Pro Preview.</p>
      <p><a href="https://github.com/forrtproject/replicatethis" target="_blank">View repository on GitHub</a></p>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('darkModeToggle');
    const doc = document.documentElement;
    toggle.addEventListener('click', () => {
      doc.classList.toggle('dark-mode');
      localStorage.setItem('theme', doc.classList.contains('dark-mode') ? 'dark' : 'light');
    });
  </script>
</body>
</html>
